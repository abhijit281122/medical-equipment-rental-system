<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../../../../styles/machine.css" xmlns="http://javafx.com/javafx/8.0.141" xmlns:fx="http://javafx.com/fxml/1" fx:controller="allController.CustomerController">

    <top>
        <HBox styleClass="header">
            <Label styleClass="header-title" text="Customer Management" />
        </HBox>
    </top>

    <center>
        <HBox spacing="25" styleClass="content-area">

            <!-- LEFT FORM -->
            <VBox prefWidth="380" spacing="15" styleClass="form-card">

                <Label styleClass="section-title" text="Customer Details" />

                <GridPane hgap="10" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="35" />
                        <ColumnConstraints percentWidth="65" />
                    </columnConstraints>

                    <Label text="Full Name" />
                    <TextField fx:id="nameField" GridPane.columnIndex="1" />

                    <Label text="Phone / Mobile" GridPane.rowIndex="1" />
                    <TextField fx:id="phoneField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label text="Address" GridPane.rowIndex="2" />
                    <TextArea fx:id="addressField" prefRowCount="2" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label text="Location" GridPane.rowIndex="3" />
                    <TextField fx:id="locationField" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label text="Reference By" GridPane.rowIndex="4" />
                    <ComboBox fx:id="referenceComboBox" prefHeight="45.0" prefWidth="218.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>

                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button onAction="#insertCustomer" text="Save" />
                    <Button onAction="#clearForm" text="Clear" />
                </HBox>

            </VBox>

            <!-- RIGHT TABLE -->
            <VBox spacing="15" HBox.hgrow="ALWAYS">

                <TableView fx:id="customerTable" VBox.vgrow="ALWAYS">

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>

                    <columns>
                        <TableColumn fx:id="colId" text="ID" />
                        <TableColumn fx:id="colName" text="Full Name" />
                        <TableColumn fx:id="colPhone" text="Phone" />
                        <TableColumn fx:id="colLocation" text="Location" />
                        <TableColumn fx:id="colReference" text="Reference By" />
                    </columns>
                </TableView>

                <Pagination fx:id="pagination" />

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button onAction="#updateCustomer" text="Edit" />
                    <Button onAction="#deleteCustomer" text="Delete" />
                </HBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>
