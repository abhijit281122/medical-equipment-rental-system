<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      styleClass="page-bg"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@../../../../styles/rentpage.css"
      fx:controller="allController.EmployeeController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- 🔹 PAGE TITLE -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <ImageView fitHeight="28" fitWidth="28" preserveRatio="true">
            <image>
                <Image url="@/images/icons/users.png"/>
            </image>
        </ImageView>
        <Label text="Employee Management" styleClass="page-title"/>
    </HBox>

    <!-- 🔹 FORM CARD -->
    <VBox spacing="20" styleClass="card">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <!-- FORM GRID -->
        <GridPane hgap="20" vgap="15">
            <columnConstraints>
                <ColumnConstraints prefWidth="180"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Employee Code"/>
            <TextField fx:id="codeField" promptText="EMP-001" GridPane.columnIndex="1"/>

            <Label text="Name" GridPane.rowIndex="1"/>
            <TextField fx:id="nameField" promptText="Enter employee name"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Role" GridPane.rowIndex="2"/>
            <TextField fx:id="roleField" promptText="Technician / Manager"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Phone" GridPane.rowIndex="3"/>
            <TextField fx:id="phoneField" promptText="10-digit mobile number"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="Email" GridPane.rowIndex="4"/>
            <TextField fx:id="emailField" promptText="example@email.com"
                       GridPane.columnIndex="1" GridPane.rowIndex="4"/>

            <Label text="Address" GridPane.rowIndex="5"/>
            <TextArea fx:id="addressField" promptText="Enter full address"
                      prefRowCount="3" maxHeight="80" wrapText="true"
                      GridPane.columnIndex="1" GridPane.rowIndex="5"/>
        </GridPane>

        <!-- 🔹 ACTION BUTTON BAR -->
        <HBox spacing="15" alignment="CENTER_RIGHT">

            <Button text=" Save" onAction="#saveEmployee" styleClass="btn-primary">
                <graphic>
                    <ImageView fitHeight="16" fitWidth="16">
                        <image><Image url="@/images/icons/save.png"/></image>
                    </ImageView>
                </graphic>
            </Button>

            <Button text=" Update" onAction="#updateEmployee">
                <graphic>
                    <ImageView fitHeight="16" fitWidth="16">
                        <image><Image url="@/images/icons/edit.png"/></image>
                    </ImageView>
                </graphic>
            </Button>

            <Button text=" Delete" onAction="#deleteEmployee" styleClass="btn-danger">
                <graphic>
                    <ImageView fitHeight="16" fitWidth="16">
                        <image><Image url="@/images/icons/delete.png"/></image>
                    </ImageView>
                </graphic>
            </Button>

            <Button text=" Clear" onAction="#clearForm">
                <graphic>
                    <ImageView fitHeight="16" fitWidth="16">
                        <image><Image url="@/images/icons/clear.png"/></image>
                    </ImageView>
                </graphic>
            </Button>

        </HBox>
    </VBox>

    <!-- 🔹 TABLE CARD -->
    <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">

        <HBox alignment="CENTER_LEFT" spacing="10">
            <ImageView fitHeight="18" fitWidth="18">
                <image>
                    <Image url="@/images/icons/table.png"/>
                </image>
            </ImageView>
            <Label text="Employees" styleClass="card-title"/>
        </HBox>

        <TableView fx:id="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="codeCol" text="Code" prefWidth="120"/>
                <TableColumn fx:id="nameCol" text="Name" prefWidth="220"/>
                <TableColumn fx:id="roleCol" text="Role" prefWidth="150"/>
                <TableColumn fx:id="phoneCol" text="Phone" prefWidth="160"/>
                <TableColumn fx:id="emailCol" text="Email" prefWidth="220"/>
                <TableColumn fx:id="addressCol" text="Address" prefWidth="250"/>
            </columns>
        </TableView>

        <Pagination fx:id="pagination" maxPageIndicatorCount="5" prefHeight="40"/>
    </VBox>

</VBox>
