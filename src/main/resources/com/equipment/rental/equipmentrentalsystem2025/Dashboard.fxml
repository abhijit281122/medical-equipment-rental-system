<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.141"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="allController.DashboardController"
            stylesheets="@../../../../styles/dashboard.css"
            maxWidth="Infinity"
            maxHeight="Infinity">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox prefWidth="250"
              spacing="15"
              styleClass="side-bar"
              maxHeight="Infinity">

            <padding>
                <Insets top="20" left="15" right="15" bottom="20"/>
            </padding>

            <!-- TITLE -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
                    <image>
                        <Image url="@/images/Heart-Monitor.png"/>
                    </image>
                </ImageView>
                <Label text="Machine Rental System"
                       wrapText="true"
                       styleClass="side-title"/>
            </HBox>

            <Separator/>

            <!-- MAIN NAV -->
            <VBox spacing="8">

                <Button fx:id="homeBtn" text="Home"
                        styleClass="nav-btn"
                        onAction="#openHomePage">
                    <graphic>
                        <ImageView fitHeight="18" fitWidth="18">
                            <Image url="@/images/icons/home.png"/>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="machineMasterBtn" text="Machine Master"
                        styleClass="nav-btn"
                        onAction="#openMachineMasterPage">
                    <graphic>
                        <ImageView fitHeight="18" fitWidth="18">
                            <Image url="@/images/icons/list.png"/>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="machineUnitBtn" text="Machine Unit"
                        styleClass="nav-btn"
                        onAction="#openMachineUnitPage">
                    <graphic>
                        <ImageView fitHeight="18" fitWidth="18">
                            <Image url="@/images/icons/plus.png"/>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="rentMachineBtn" text="Rent Machine"
                        styleClass="nav-btn"
                        onAction="#openRentMachinePage">
                    <graphic>
                        <ImageView fitHeight="18" fitWidth="18">
                            <Image url="@/images/icons/cart.png"/>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="employeeBtn" text="Employees"
                        styleClass="nav-btn"
                        onAction="#openEmployeePage">
                    <graphic>
                        <ImageView fitHeight="18" fitWidth="18">
                            <Image url="@/images/icons/users.png"/>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="employeeRoleBtn" text="Employee Roles"
                        styleClass="nav-btn"
                        onAction="#openEmployeeRolePage">
                    <graphic>
                        <ImageView fitHeight="18" fitWidth="18">
                            <Image url="@/images/icons/role.png"/>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="customerBtn" text="Customer / Patients"
                        styleClass="nav-btn"
                        onAction="#openCustomerPage">
                    <graphic>
                        <ImageView fitHeight="18" fitWidth="18">
                            <Image url="@/images/icons/users.png"/>
                        </ImageView>
                    </graphic>
                </Button>

            </VBox>

            <Separator/>

            <!-- REPORTS SECTION -->
            <Label text="Reports" styleClass="report-label"/>

            <VBox spacing="8">
                <Button fx:id="activeRentBtn" text="Active Rent" styleClass="nav-btn" onAction="#showActiveRentPage"/>
                <Button fx:id="closedRentBtn" text="Closed Rent" styleClass="nav-btn" onAction="#showClosedRentPage"/>
                <Button fx:id="dueDetailsBtn" text="Due Details (Period)" styleClass="nav-btn" onAction="#showDueRentPage"/>
                <Button fx:id="dateWiseDueBtn" text="Date-wise Due List" styleClass="nav-btn"/>
                <Button fx:id="weeklyCollectionBtn" text="Weekly Collection" styleClass="nav-btn" onAction="#showWeeklyCollectionPage"/>
            </VBox>

            <!-- THIS PUSHES CONTENT UP AND MAKES SIDEBAR FULL HEIGHT -->
            <Region VBox.vgrow="ALWAYS"/>

        </VBox>
    </left>

    <!-- ================= TOP BAR ================= -->
    <top>
        <HBox fx:id="topBar"
              styleClass="top-bar"
              prefHeight="60"
              minHeight="60"
              maxHeight="60"
              alignment="CENTER_LEFT">

            <padding>
                <Insets top="0" bottom="0" left="20" right="20"/>
            </padding>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="usernameLabel"
                   text="Welcome, Admin"
                   styleClass="username-label"/>

            <Button fx:id="logoutBtn"
                    text="Logout"
                    styleClass="logout-btn"/>
        </HBox>
    </top>

    <!-- ================= CENTER CONTENT ================= -->
    <center>
        <StackPane fx:id="contentArea"
                   styleClass="page-bg"
                   maxWidth="Infinity"
                   maxHeight="Infinity">

            <!-- HOME PAGE -->
            <VBox fx:id="homePage"
                  spacing="20"
                  alignment="TOP_CENTER"
                  maxWidth="Infinity"
                  maxHeight="Infinity">
                <padding>
                    <Insets top="20" bottom="20" left="20" right="20"/>
                </padding>

                <!-- ROW 1 -->
                <GridPane hgap="16" vgap="16"
                          maxWidth="Infinity"
                          maxHeight="Infinity">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS"/>
                    </columnConstraints>

                    <VBox styleClass="dashboard-card"
                          alignment="CENTER"
                          maxWidth="Infinity"
                          onMouseClicked="#openTotalMachines">
                        <Label text="Total Machines" styleClass="card-title"/>
                        <Label fx:id="totalMachineLabel" text="0" styleClass="card-value"/>
                    </VBox>

                    <VBox styleClass="dashboard-card" alignment="CENTER" maxWidth="Infinity" onMouseClicked="#openAvailableMachines" GridPane.columnIndex="1">
                        <Label text="Available Machines" styleClass="card-title"/>
                        <Label fx:id="availableMachinesLabel" text="0" styleClass="card-value"/>
                    </VBox>

                    <VBox styleClass="dashboard-card" alignment="CENTER" maxWidth="Infinity" GridPane.columnIndex="2">
                        <Label text="Total Rentals" styleClass="card-title"/>
                        <Label fx:id="totalRentalsLabel" text="0" styleClass="card-value"/>
                    </VBox>
                </GridPane>

                <!-- ROW 2 -->
                <GridPane hgap="16" vgap="16"
                          maxWidth="Infinity"
                          maxHeight="Infinity">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="33.33" hgrow="ALWAYS"/>
                    </columnConstraints>

                    <children>
                        <VBox styleClass="dashboard-card" alignment="CENTER" maxWidth="Infinity" onMouseClicked="#openActiveRents">
                            <Label text="Active Rent" styleClass="card-title"/>
                            <Label fx:id="activeRentsLabel" text="0" styleClass="card-value"/>
                        </VBox>

                        <VBox styleClass="dashboard-card" alignment="CENTER" maxWidth="Infinity" onMouseClicked="#openClosedRents" GridPane.columnIndex="1">
                            <Label text="Closed Rent" styleClass="card-title"/>
                            <Label fx:id="closedRentsLabel" text="0" styleClass="card-value"/>
                        </VBox>

                        <VBox styleClass="dashboard-card" alignment="CENTER" maxWidth="Infinity" onMouseClicked="#openDueRents" GridPane.columnIndex="2">
                            <Label text="Due With Period" styleClass="card-title"/>
                            <Label fx:id="dueWithinPeriodLabel" text="0" styleClass="card-value"/>
                        </VBox>
                    </children>
                </GridPane>

                <!-- ROW 3 -->
                <GridPane hgap="16" vgap="16"
                          maxWidth="Infinity"
                          maxHeight="Infinity">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                    </columnConstraints>

                    <VBox styleClass="dashboard-card" alignment="CENTER" maxWidth="Infinity">
                        <Label text="Date-wise Due" styleClass="card-title"/>
                        <Label fx:id="dateWiseDueLabel" text="0" styleClass="card-value"/>
                    </VBox>

                    <VBox styleClass="dashboard-card" alignment="CENTER" maxWidth="Infinity" GridPane.columnIndex="1">
                        <Label text="Weekly Collection" styleClass="card-title"/>
                        <Label fx:id="weeklyCollectionLabel" text="0" styleClass="card-value"/>
                    </VBox>
                </GridPane>

                <!-- CHART -->
                <BarChart fx:id="machineChart"
                          VBox.vgrow="ALWAYS"
                          maxWidth="Infinity"
                          styleClass="chart">
                    <xAxis>
                        <CategoryAxis label="Machines"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Units"/>
                    </yAxis>
                </BarChart>

            </VBox>

        </StackPane>
    </center>

</BorderPane>