<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@../../../../styles/machine.css"
            xmlns="http://javafx.com/javafx/8.0.141"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="allController.EmployeeRoleController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header">
            <Label styleClass="header-title" text="Employee Role Management"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="25" styleClass="content-area">

            <!-- LEFT FORM -->
            <VBox prefWidth="350" spacing="15" styleClass="form-card">

                <Label styleClass="section-title" text="Role Details"/>

                <GridPane hgap="10" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="35"/>
                        <ColumnConstraints percentWidth="65"/>
                    </columnConstraints>

                    <Label text="Role Name"/>
                    <TextField fx:id="roleNameField" GridPane.columnIndex="1"/>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button text="Save" onAction="#saveRole"/>
                    <Button text="Clear" onAction="#clearForm"/>
                </HBox>

            </VBox>

            <!-- RIGHT TABLE -->
            <VBox spacing="15" HBox.hgrow="ALWAYS">

                <TableView fx:id="roleTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>

                    <columns>
                        <TableColumn fx:id="colId" text="ID"/>
                        <TableColumn fx:id="colRoleName" text="Role Name"/>
                    </columns>
                </TableView>

                <Pagination fx:id="pagination"/>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button text="Edit"/>
                    <Button text="Delete" onAction="#deleteRole"/>
                </HBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>