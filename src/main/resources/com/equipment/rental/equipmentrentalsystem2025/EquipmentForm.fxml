<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<AnchorPane prefHeight="800.0"
            prefWidth="1100.0"
            stylesheets="@../../../../styles/rentpage.css"
            xmlns="http://javafx.com/javafx/8.0.141"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="allController.EquipmentFormController">

    <!-- TOP HEADER -->
    <HBox alignment="CENTER_LEFT"
          prefHeight="60"
          prefWidth="1100"
          spacing="15"
          style="-fx-background-color:#294d90; -fx-padding:10;">

        <ImageView fitHeight="48" fitWidth="48" preserveRatio="true">
            <image>
                <Image url="@/images/icons/cube.png"/>
            </image>
        </ImageView>
        <Label text="Equipment Master"
               style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;"/>
    </HBox>

    <!-- MAIN CONTENT -->
    <VBox spacing="20"
          style="-fx-padding:25;"
          AnchorPane.topAnchor="60"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          AnchorPane.bottomAnchor="0">

        <!-- FORM -->
        <GridPane hgap="16" vgap="12" maxWidth="700">

            <columnConstraints>
                <ColumnConstraints percentWidth="35"/>
                <ColumnConstraints percentWidth="65"/>
            </columnConstraints>

            <!-- ROW 0 -->
            <Label text="Equipment ID" GridPane.rowIndex="0"/>
            <TextField fx:id="equipmentIdField"
                       editable="false"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="0"/>

            <!-- ROW 1 -->
            <Label text="Equipment Name" GridPane.rowIndex="1"/>
            <TextField fx:id="nameField"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="1"/>

            <!-- ROW 2 -->
            <Label text="Category" GridPane.rowIndex="2"/>
            <TextField fx:id="categoryField"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="2"/>

            <!-- ROW 3 -->
            <Label text="Condition" GridPane.rowIndex="3"/>
            <ComboBox fx:id="conditionBox"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="3"/>

            <!-- ROW 4 -->
            <Label text="Manufacturer" GridPane.rowIndex="4"/>
            <TextField fx:id="manufacturerField"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="4"/>

            <!-- ROW 5 -->
            <Label text="Serial Number" GridPane.rowIndex="5"/>
            <TextField fx:id="serialNumberField"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="5"/>

            <!-- ROW 6 -->
            <Label text="Rental Price" GridPane.rowIndex="6"/>
            <TextField fx:id="priceField"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="6"/>

        </GridPane>

        <!-- BUTTONS -->
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button fx:id="saveBtn" text="Save Equipment"/>
        </HBox>

        <!-- NOTE -->
        <Label styleClass="label-note"
               text="Note: Equipment ID is auto-generated for demo purpose."/>

    </VBox>

</AnchorPane>
