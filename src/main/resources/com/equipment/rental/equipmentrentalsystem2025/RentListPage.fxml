<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<AnchorPane prefHeight="800.0"
            prefWidth="1100.0"
            stylesheets="@../../../../styles/machine.css"
            xmlns="http://javafx.com/javafx/8.0.141"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="allController.RentListController">

    <!-- ================= HEADER ================= -->
    <HBox alignment="CENTER_LEFT"
          prefHeight="60"
          prefWidth="1100"
          spacing="15"
          style="-fx-background-color:#294d90; -fx-padding:10;">

        <ImageView fitHeight="48" fitWidth="48" preserveRatio="true">
            <image>
                <Image url="@/images/icons/rental.png"/>
            </image>
        </ImageView>

        <Label fx:id="pageTitle"
               text="Rent List"
               style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;"/>
    </HBox>

    <!-- ================= MAIN CONTENT ================= -->
    <VBox spacing="15"
          style="-fx-padding:20;"
          AnchorPane.topAnchor="60"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          AnchorPane.bottomAnchor="0">

        <!-- SEARCH BAR -->
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Label text="Search:"
                   style="-fx-font-weight:bold;"/>

            <TextField fx:id="searchField"
                       promptText="Search by Challan, Customer, Machine..."
                       prefWidth="300"/>
        </HBox>

        <!-- ================= TABLE ================= -->
        <TableView fx:id="rentTable" VBox.vgrow="ALWAYS">

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>

            <columns>

                <TableColumn fx:id="challanCol" text="Challan No" minWidth="120"/>
                <TableColumn fx:id="customerCol" text="Customer" minWidth="150"/>
                <TableColumn fx:id="machineCol" text="Machine" minWidth="150"/>
                <TableColumn fx:id="unitCol" text="Serial No" minWidth="120"/>
                <TableColumn fx:id="startDateCol" text="Start Date" minWidth="120"/>
                <TableColumn fx:id="returnDateCol" text="Expected Return" minWidth="130"/>
                <TableColumn fx:id="daysCol" text="Days" minWidth="70"/>
                <TableColumn fx:id="totalCol" text="Total" minWidth="100"/>
                <TableColumn fx:id="paidCol" text="Paid" minWidth="100"/>
                <TableColumn fx:id="dueCol" text="Due" minWidth="100"/>
                <TableColumn fx:id="statusCol" text="Status" minWidth="100"/>

            </columns>
        </TableView>

        <!-- ================= BOTTOM BUTTONS ================= -->
        <HBox alignment="CENTER_RIGHT" spacing="15">

            <Button fx:id="importExcelBtn"
                    text="Import Excel"
                    style="-fx-background-color:#4CAF50; -fx-text-fill:white;"/>

            <Button fx:id="exportPdfBtn"
                    text="Export PDF"
                    style="-fx-background-color:#d9534f; -fx-text-fill:white;"/>

        </HBox>

    </VBox>

</AnchorPane>