<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<BorderPane stylesheets="@../../../../styles/machine.css" xmlns="http://javafx.com/javafx/8.0.141"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="allController.RentMachinePageController">

    <!-- ================= HEADER ================= -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header">
            <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
                <image>
                    <Image url="@../../../../images/icons/rental.png"/>
                </image>
            </ImageView>
            <Label styleClass="header-title" text="Machine Rental"/>
        </HBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>
        <HBox spacing="25" styleClass="content-area" HBox.hgrow="ALWAYS">
            <!-- ================= LEFT : RENTAL FORM ================= -->
            <VBox prefWidth="420" spacing="15" styleClass="form-card">

                <Label styleClass="section-title" text="Rental Entry"/>

                    <GridPane hgap="10" vgap="12">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="40"/>
                            <ColumnConstraints percentWidth="60"/>
                        </columnConstraints>

                        <!-- Machine -->
                        <Label text="Select Machine" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="machineDropdown" promptText="Select Machine"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <!-- Machine No -->
                        <Label text="Machine No" GridPane.rowIndex="1"/>
                        <ComboBox fx:id="machineUnitDropdown" promptText="Select Machine No."
                                  GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <!-- Customer -->
                        <Label text="Patient / Customer Name" GridPane.rowIndex="2"/>
                        <ComboBox fx:id="customerDropdown" promptText="Select Patient / Customer"
                                  GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <!-- Address -->
                        <Label text="Address" GridPane.rowIndex="3"/>
                        <TextField fx:id="customerAddressField" editable="false" promptText="Address"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <!-- Location -->
                        <Label text="Location" GridPane.rowIndex="4"/>
                        <TextField fx:id="customerLocationField" editable="false" promptText="Location"
                                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                        <!-- Mobile -->
                        <Label text="Mobile / Phone" GridPane.rowIndex="5"/>
                        <TextField fx:id="customerMobileField" editable="false" promptText="Mobile / Phone"
                                   GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                        <!-- Challan -->
                        <Label text="Delivery / Challan No" GridPane.rowIndex="6"/>
                        <TextField fx:id="challanField" editable="false" promptText="Delivery / Challan No"
                                   GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                        <!-- Staff -->
                        <Label text="Staff" GridPane.rowIndex="7"/>
                        <ComboBox fx:id="staffDropdown" promptText="Select Staff"
                                  GridPane.columnIndex="1" GridPane.rowIndex="7"/>

                        <!-- Rent Start -->
                        <Label text="Rent Received Date" GridPane.rowIndex="8"/>
                        <DatePicker fx:id="rentStartDatePicker" promptText="Rent Received Date"
                                    GridPane.columnIndex="1" GridPane.rowIndex="8"/>

                        <!-- Rent End -->
                        <Label text="Rent End Date" GridPane.rowIndex="9"/>
                        <DatePicker fx:id="rentEndDatePicker" promptText="Rent End Date"
                                    GridPane.columnIndex="1" GridPane.rowIndex="9"/>

                        <!-- Actual Return -->
                        <Label text="Actual Received Date" GridPane.rowIndex="10"/>
                        <DatePicker fx:id="actualReturnDatePicker" disable="true"
                                    promptText="Actual Received Date"
                                    GridPane.columnIndex="1" GridPane.rowIndex="10"/>

                        <!-- Rent Collected By -->
                        <Label text="Rent Collected By" GridPane.rowIndex="11"/>
                        <ComboBox fx:id="rentCollectedByDropdown" promptText="Collected By"
                                  GridPane.columnIndex="1" GridPane.rowIndex="11"/>

                        <!-- Total Amount -->
                        <Label text="Price" GridPane.rowIndex="12"/>
                        <TextField fx:id="priceField" editable="true"
                                   promptText="Price"
                                   GridPane.columnIndex="1" GridPane.rowIndex="12"/>

                    </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button fx:id="addToCartBtn" text="Add To List"/>
                    <Button fx:id="clearBtn" text="Clear"/>
                </HBox>

            </VBox>

            <!-- ================= RIGHT : TABLE ================= -->
            <VBox spacing="15" HBox.hgrow="ALWAYS">

                <Label styleClass="section-title" text="Rental List"/>

                <TableView fx:id="rentalTable" VBox.vgrow="ALWAYS" minHeight="200">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>

                    <columns>
                        <TableColumn fx:id="colSerial" text="Serial No"/>
                        <TableColumn fx:id="colMachineInfo" text="Machine Name / No"/>
                        <TableColumn fx:id="colPrice" text="Price"/>
                        <TableColumn fx:id="colCustomerName" text="Customer Name"/>
                        <TableColumn fx:id="colStartDate" text="Rent Start"/>
                        <TableColumn fx:id="colEndDate" text="Rent End"/>
                    </columns>
                </TableView>

                <!-- ================= BILL SUMMARY ================= -->
                <VBox spacing="10" styleClass="form-card">

                    <Label styleClass="section-title" text="Bill Summary"/>

                    <GridPane hgap="10" vgap="10">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Grand Total -->
                        <Label text="Grand Total" GridPane.rowIndex="0"/>
                        <TextField fx:id="totalAmountField"
                                   editable="false"
                                   promptText="Grand Total"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="0"/>

                        <!-- Paid Amount -->
                        <Label text="Paid Amount" GridPane.rowIndex="1"/>
                        <TextField fx:id="paidAmountField"
                                   promptText="Enter Paid Amount"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1"/>

                        <!-- Due Amount -->
                        <Label text="Due Amount" GridPane.rowIndex="2"/>
                        <TextField fx:id="dueAmountField"
                                   editable="false"
                                   promptText="Due Amount"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="2"/>

                    </GridPane>

                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="10" minHeight="50">
                    <Button fx:id="saveBtn" text="Save Rental"/>
                </HBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>
