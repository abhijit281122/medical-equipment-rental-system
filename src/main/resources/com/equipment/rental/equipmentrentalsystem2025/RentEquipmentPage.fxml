<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<AnchorPane prefHeight="800.0" prefWidth="1100.0" stylesheets="@../../../../styles/rentpage.css"
            xmlns="http://javafx.com/javafx/8.0.141" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="allController.RentEquipmentPageController">

    <!-- TOP HEADING -->
    <HBox alignment="CENTER_LEFT" layoutX="0" layoutY="0" prefHeight="60" prefWidth="1100" spacing="15"
          style="-fx-background-color:#294d90; -fx-padding:10;">
        <children>
            <ImageView fitHeight="48" fitWidth="48" preserveRatio="true">
                <image>
                    <Image url="@/images/icons/cube.png"/>
                </image>
            </ImageView>
            <Label style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;" text="Rent Equipment"/>
        </children>
    </HBox>

    <!-- MAIN CONTAINER BELOW TOP HEADING -->
    <VBox spacing="15" style="-fx-padding:20;" AnchorPane.topAnchor="60" AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

        <!-- FORM SECTION -->
        <GridPane hgap="16" vgap="12" maxWidth="900">
            <columnConstraints>
                <ColumnConstraints percentWidth="35"/>
                <ColumnConstraints percentWidth="65"/>
            </columnConstraints>

            <Label text="Machine:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <ComboBox fx:id="equipmentNameDropdown" prefWidth="360" promptText="Select Machine"
                      GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Machine No:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="equipmentIdField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Patient Name:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="patientNameField" promptText="Enter patient name" GridPane.columnIndex="1"
                       GridPane.rowIndex="2"/>

            <Label text="Delivery Challan No:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="challanNoField" promptText="Enter challan no" GridPane.columnIndex="1"
                       GridPane.rowIndex="3"/>

            <Label text="Staff Separation:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextField fx:id="staffSeparationField" promptText="Enter staff name" GridPane.columnIndex="1"
                       GridPane.rowIndex="4"/>

            <Label text="Rent Received Date:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
            <DatePicker fx:id="rentReceivedDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

            <Label text="Rent Collection Date:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
            <DatePicker fx:id="rentCollectionDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

            <Label text="Rent End Date:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
            <DatePicker fx:id="rentEndDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="7"/>

            <Label text="Rent Collected By:" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
            <TextField fx:id="collectedByField" promptText="Collector name" GridPane.columnIndex="1"
                       GridPane.rowIndex="8"/>

        </GridPane>

        <!-- TABLE SECTION -->
        <AnchorPane VBox.vgrow="ALWAYS">
            <TableView fx:id="rentTable"
                       AnchorPane.topAnchor="0"
                       AnchorPane.bottomAnchor="0"
                       AnchorPane.leftAnchor="0"
                       AnchorPane.rightAnchor="0"
                       prefHeight="350">

                <!-- AUTO RESIZE POLICY -->
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>

                <columns>
                    <TableColumn fx:id="colEquipment" text="Machine" minWidth="120"/>
                    <TableColumn fx:id="colMachineNo" text="Machine No" minWidth="100"/>
                    <TableColumn fx:id="colPatient" text="Patient Name" minWidth="150"/>
                    <TableColumn fx:id="colChallan" text="Challan No" minWidth="100"/>
                    <TableColumn fx:id="colStaff" text="Staff Separation" minWidth="150"/>
                    <TableColumn fx:id="colReceivedDate" text="Received Date" minWidth="120"/>
                    <TableColumn fx:id="colCollectionDate" text="Collection Date" minWidth="120"/>
                    <TableColumn fx:id="colEndDate" text="End Date" minWidth="120"/>
                    <TableColumn fx:id="colCollector" text="Collected By" minWidth="140"/>
                    <TableColumn fx:id="colTotalAmount" text="Total Amount" minWidth="100"/>
                    <TableColumn fx:id="colPaidAmount" text="Paid Amount" minWidth="100"/>
                    <TableColumn fx:id="colDueAmount" text="Due Amount" minWidth="100"/>
                </columns>
            </TableView>
        </AnchorPane>

        <!-- AMOUNT SECTION -->
        <GridPane hgap="12" vgap="10" maxWidth="400">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <Label text="Total Amount:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="totalAmountField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Paid Amount:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="paidAmountField" promptText="Enter paid amount" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Due Amount:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="dueAmountField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>

        <!-- BUTTONS BELOW TABLE -->
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button fx:id="rentAddBtn" text="Add to List"/>
            <Button fx:id="rentSubmitBtn" style="-fx-background-color:#294d90; -fx-text-fill:white;" text="Save Rental"/>
            <Button fx:id="rentClearBtn" text="Clear"/>
            <Button fx:id="rentPrintBtn" style="-fx-background-color:#1c2a4a; -fx-text-fill:white;" text="Print Challan"/>
        </HBox>

        <!-- Note -->
        <Label style="-fx-font-size:11px; -fx-text-fill:#777;"
               text="Note: Period = End Date - Received Date. Status defaults to Active."/>

    </VBox>

</AnchorPane>
